          "value": "REPLACE_WITH_BUG_REPORT_WORKFLOW_ID",
          "mode": "id"
        },
        "workflowInputs": {
          "mappingMode": "passthrough"
        },
        "options": {}
      },
      "id": "node-exec-bug-report",
      "name": "→ 01 Bug report",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [700, 640]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "a1",
              "name": "event",
              "value": "={{ $json.body.event }}",
              "type": "string"
            },
            {
              "id": "a2",
              "name": "emitted_at",
              "value": "={{ $json.body.emitted_at }}",
              "type": "string"
            },
            {
              "id": "a3",
              "name": "payload",
              "value": "={{ JSON.stringify($json.body.payload) }}",
              "type": "string"
            },
            {
              "id": "a4",
              "name": "reason",
              "value": "Unhandled event — no sub-workflow registered",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node-unhandled-log",
      "name": "Log unhandled event",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
